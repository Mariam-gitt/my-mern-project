// module.exports = mongoose.model("Word", wordSchema);

const mongoose = require("mongoose");

const wordSchema = new mongoose.Schema({

    word: {
        type: String,
        required: true
    },

    meaning: String,

    sentence: String,

    synonyms: [String],

    // review | learned
    status: {
        type: String,
        default: "review"
    },

    // Quiz tracking
    correctCount: {
        type: Number,
        default: 0
    },

    wrongCount: {
        type: Number,
        default: 0
    },

    // Flashcard review tracking
    lastReviewed: {
        type: Date
    }

},
{
    timestamps: true
});

module.exports = mongoose.model("Word", wordSchema);