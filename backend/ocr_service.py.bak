from http.server import HTTPServer, BaseHTTPRequestHandler
import json, re, os, tempfile
import numpy as np
import cv2
from PIL import Image
import pytesseract

# =========================
# Tesseract Path (Windows)
# =========================
pytesseract.pytesseract.tesseract_cmd = r"C:\Users\Ali baba Computer\AppData\Local\Programs\Tesseract-OCR\tesseract.exe"


# =========================
# 🧠 FULL PAGE OCR
# =========================
def ocr_full_page(image_path):
    img = cv2.imread(image_path)
    if img is None:
        raise Exception("Could not read image")

    rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    data = pytesseract.image_to_data(
        rgb,
        output_type=pytesseract.Output.DICT,
        config="--oem 3 --psm 6"
    )

    words = []

    for i in range(len(data["text"])):
        text = data["text"][i].strip()

        if not text:
            continue

        words.append({
            "text": text,
            "x": data["left"][i],
            "y": data["top"][i],
            "w": data["width"][i],
            "h": data["height"][i]
        })

    return words, rgb


# =========================
# 🟡 HIGHLIGHT DETECTION
# =========================
def detect_highlights(words, rgb):
    hsv = cv2.cvtColor(rgb, cv2.COLOR_RGB2HSV)

    # broad marker detection (yellow/pink/green)
    mask = cv2.inRange(
        hsv,
        np.array([10, 40, 120]),
        np.array([90, 255, 255])
    )

    highlighted = []

    for w in words:
        x, y, ww, hh = w["x"], w["y"], w["w"], w["h"]

        region = mask[y:y+hh, x:x+ww]

        if region.size == 0:
            continue

        if np.mean(region) > 15:
            highlighted.append(w["text"].lower())

    return highlighted


# =========================
# ✏️ UNDERLINE DETECTION (SMART PIXEL METHOD)
# =========================
def detect_underlines(words, rgb):
    hsv = cv2.cvtColor(rgb, cv2.COLOR_RGB2HSV)

    # detect colored ink (blue pen underline etc.)
    underline_mask = cv2.inRange(
        hsv,
        np.array([90, 50, 50]),
        np.array([140, 255, 255])
    )

    h, w = underline_mask.shape

    underlined = []

    for word in words:
        x, y, ww, hh = word["x"], word["y"], word["w"], word["h"]

        # region slightly below word
        y1 = min(h - 1, y + hh)
        y2 = min(h, y + hh + 10)

        region = underline_mask[y1:y2, x:x+ww]

        if region.size == 0:
            continue

        if np.mean(region) > 5:
            underlined.append(word["text"].lower())

    return underlined


# =========================
# 🧹 CLEANUP
# =========================
def deduplicate(words):
    seen = set()
    return [w for w in words if not (w in seen or seen.add(w))]


# =========================
# 🌐 HTTP SERVER
# =========================
class OCRHandler(BaseHTTPRequestHandler):

    def do_POST(self):
        if self.path != "/extract":
            return

        # prevent hanging socket issues
        self.connection.settimeout(10)

        try:
            length = int(self.headers["Content-Length"])
            data = self.rfile.read(length)

            content_type = self.headers.get("Content-Type", "")
            ext = ".png" if "png" in content_type else ".jpg"

            with tempfile.NamedTemporaryFile(suffix=ext, delete=False) as tmp:
                tmp.write(data)
                path = tmp.name

            try:
                words, rgb = ocr_full_page(path)

                highlighted = detect_highlights(words, rgb)
                underlined = detect_underlines(words, rgb)

                all_words = deduplicate(highlighted + underlined)

                self._respond(200, {
                    "words": all_words,
                    "highlighted": deduplicate(highlighted),
                    "underlined": deduplicate(underlined),
                    "total": len(all_words)
                })

            except Exception as e:
                self._respond(500, {"error": str(e)})

            finally:
                os.unlink(path)

        except Exception as e:
            self._respond(500, {"error": str(e)})

    def do_GET(self):
        if self.path == "/status":
            self._respond(200, {"status": "running"})

    # =========================
    # SAFE RESPONSE (FIXES WINERROR 10053)
    # =========================
    def _respond(self, code, data):
        try:
            body = json.dumps(data).encode()

            self.send_response(code)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()

            self.wfile.write(body)

        except (ConnectionAbortedError, BrokenPipeError, ConnectionResetError):
            print("[OCR] Client disconnected early (safe ignore)")

    def log_message(self, fmt, *args):
        print("[OCR]", fmt % args)


# =========================
# RUN SERVER
# =========================
if __name__ == "__main__":
    print("OCR service running 🚀 (stable version)")
    server = HTTPServer(("localhost", 5003), OCRHandler)
    server.serve_forever()