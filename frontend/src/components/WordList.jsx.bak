

function WordList({ words }) {

    if (!words || words.length === 0) {
        return <h3>No words found</h3>;
    }

    return (

        <div>

            <h2>Word List</h2>

            {words.map((w) => (

                <div key={w._id} style={{
                    border: "1px solid black",
                    margin: "10px",
                    padding: "10px"
                }}>

                    <h3>{w.word}</h3>
                    <p>{w.meaning}</p>
                    <p>{w.sentence}</p>

                </div>

            ))}

        </div>
    );
}

export default WordList;


