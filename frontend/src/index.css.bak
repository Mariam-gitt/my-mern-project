@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap');

:root {
  --black: #111111;
  --dark: #1a1a1a;
  --mid: #555555;
  --border: #d8d8d8;
  --border-strong: #aaaaaa;
  --light: #f0f0f0;
  --white: #ffffff;
  --bg: #fafafa;
  --red: #c0392b;
  --red-hover: #a93226;
  --red-light: #fdecea;
  --text: #111111;
  --text-muted: #777777;
  --sidebar-w: 200px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

h1, h2, h3 { font-family: 'Playfair Display', serif; }

/* ── SIDEBAR ── */
.sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  background: var(--black);
  position: fixed;
  top: 0; left: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  border-right: 2px solid #222;
}

.sidebar-brand {
  padding: 24px 20px 18px;
  border-bottom: 1px solid #222;
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.sidebar-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--white);
  letter-spacing: -0.3px;
}

.sidebar-tagline {
  font-size: 0.62rem;
  color: #555;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.sidebar-nav { flex: 1; padding: 10px 0; }

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 10px 20px;
  font-size: 0.82rem;
  font-weight: 500;
  color: #777;
  cursor: pointer;
  transition: all 0.12s;
  border-left: 2px solid transparent;
}

.sidebar-link:hover { color: var(--white); background: rgba(255,255,255,0.04); }
.sidebar-link.active { color: var(--white); border-left-color: var(--red); background: rgba(255,255,255,0.06); }
.sidebar-link .link-icon { font-size: 0.85rem; width: 16px; text-align: center; }

.sidebar-bottom { padding: 12px 0; border-top: 1px solid #222; }

.sidebar-logout {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 10px 20px;
  font-size: 0.8rem;
  color: #555;
  cursor: pointer;
  transition: color 0.12s;
}

.sidebar-logout:hover { color: var(--red); }

/* ── MAIN CONTENT — offset by sidebar width ── */
.app-layout { display: flex; }

.main-content {
  margin-left: var(--sidebar-w);
  flex: 1;
  min-height: 100vh;
  background: var(--white);
}

/* ── READER uses full height differently ── */
.reader-layout {
  margin-left: var(--sidebar-w);
  display: grid;
  grid-template-columns: 1fr 340px;
  height: 100vh;
  overflow: hidden;
}

/* ── PAGE CONTAINER ── */
.page-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 40px 40px;
}

.page-header {
  margin-bottom: 32px;
  padding-bottom: 18px;
  border-bottom: 2px solid var(--black);
}

.page-header h1 {
  font-size: 2rem;
  font-weight: 700;
  letter-spacing: -1px;
  margin-bottom: 4px;
}

.page-header p { color: var(--text-muted); font-size: 0.85rem; }

/* ── AUTH ── */
.auth-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
}

.auth-card {
  background: var(--white);
  border: 2px solid var(--black);
  padding: 44px 40px;
  width: 100%;
  max-width: 380px;
}

.auth-title { font-size: 1.8rem; font-weight: 700; margin-bottom: 4px; letter-spacing: -0.5px; }
.auth-subtitle { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 28px; }

.input-group { display: flex; flex-direction: column; gap: 10px; margin-bottom: 18px; }

/* ── INPUTS ── */
input[type="text"],
input[type="email"],
input[type="password"],
input:not([type]),
textarea.context-textarea {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid var(--border);
  background: var(--white);
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  color: var(--text);
  outline: none;
  transition: border-color 0.12s;
}

input:focus, textarea.context-textarea:focus { border-color: var(--black); }

/* ── BUTTONS ── */
.btn {
  padding: 11px 20px;
  border: 2px solid transparent;
  font-family: 'Inter', sans-serif;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.12s;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.btn-primary { background: var(--red); color: var(--white); border-color: var(--red); width: 100%; }
.btn-primary:hover { background: var(--red-hover); border-color: var(--red-hover); }
.btn-primary:disabled { opacity: 0.45; cursor: not-allowed; }

.btn-ghost { background: transparent; color: var(--text); border-color: var(--border); }
.btn-ghost:hover { border-color: var(--black); }
.btn-ghost:disabled { opacity: 0.35; cursor: not-allowed; }

.auth-link { text-align: center; margin-top: 18px; font-size: 0.82rem; color: var(--text-muted); }
.auth-link span { color: var(--red); font-weight: 600; cursor: pointer; text-decoration: underline; }

/* ── STATS ROW ── */
.stats-row {
  display: flex;
  gap: 0;
  margin-bottom: 28px;
  border: 2px solid var(--black);
}

.stat-card {
  flex: 1;
  padding: 18px 20px;
  border-right: 1px solid var(--border-strong);
  cursor: default;
  transition: background 0.12s;
  background: var(--white);
}

.stat-card:last-child { border-right: none; }
.stat-card.clickable { cursor: pointer; }
.stat-card.clickable:hover { background: var(--bg); }

.stat-number {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--black);
  line-height: 1;
}

.stat-label {
  font-size: 0.68rem;
  color: var(--text-muted);
  margin-top: 4px;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

/* ── ADD WORD BOX ── */
.add-word-box {
  display: flex;
  margin-bottom: 28px;
  border: 2px solid var(--black);
  background: var(--white);
}

.add-word-box input {
  flex: 1;
  margin: 0;
  border: none;
  padding: 13px 16px;
  font-size: 0.92rem;
  background: transparent;
}

.add-word-box input:focus { border: none; outline: none; }

.add-word-box .btn {
  width: auto;
  white-space: nowrap;
  border: none;
  border-left: 2px solid var(--black);
  padding: 11px 20px;
}

/* ── SECTION TITLE ── */
.section-title {
  font-size: 0.68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 12px;
  font-family: 'Inter', sans-serif;
}

/* ── WORD LIST ── */
.word-list {
  border: 2px solid var(--black);
  background: var(--white);
}

.word-card {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
  background: var(--white);
}

.word-card:last-child { border-bottom: none; }
.word-card:hover { background: var(--bg); }
.word-card.learned { background: #fafafa; }

.word-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 5px;
}

.word-card-top h3 { font-size: 1rem; font-weight: 600; font-family: 'Playfair Display', serif; }

.word-card-word-link {
  cursor: pointer;
  text-decoration: underline;
  text-decoration-style: dotted;
  text-underline-offset: 3px;
}

.word-card-word-link:hover { color: var(--red); }
.word-card .meaning { font-size: 0.85rem; color: #444; line-height: 1.55; }
.word-card .example { font-size: 0.8rem; color: var(--text-muted); font-style: italic; margin-top: 5px; padding-top: 5px; border-top: 1px solid var(--border); }

/* ── STATUS BUTTONS ── */
.status-btn {
  padding: 3px 10px;
  border: 1.5px solid;
  font-family: 'Inter', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.12s;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  white-space: nowrap;
  background: transparent;
}

.status-btn.review { border-color: var(--border); color: var(--text-muted); }
.status-btn.review:hover { border-color: var(--black); color: var(--black); }
.status-btn.learned { background: var(--black); border-color: var(--black); color: var(--white); }
.status-btn.learned:hover { background: #333; }

/* ── FILTER TABS ── */
.filter-tabs {
  display: flex;
  margin-bottom: 16px;
  border: 2px solid var(--black);
  background: var(--white);
}

.filter-tab {
  flex: 1;
  padding: 9px 12px;
  border: none;
  border-right: 1px solid var(--border);
  background: transparent;
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  font-weight: 500;
  cursor: pointer;
  color: var(--text-muted);
  transition: all 0.12s;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.filter-tab:last-child { border-right: none; }
.filter-tab:hover { background: var(--bg); color: var(--black); }
.filter-tab.active { background: var(--black); color: var(--white); font-weight: 600; }

/* ── SEARCH INPUT STANDALONE ── */
.search-input {
  width: 100%;
  padding: 11px 14px;
  border: 2px solid var(--black);
  background: var(--white);
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  color: var(--text);
  outline: none;
  margin-bottom: 12px;
  transition: border-color 0.12s;
}

.search-input:focus { border-color: var(--red); }

/* ── EMPTY STATE ── */
.empty-state {
  text-align: center;
  padding: 50px 20px;
  color: var(--text-muted);
  border: 2px dashed var(--border);
  background: var(--white);
}

.empty-state .emoji { font-size: 2rem; margin-bottom: 10px; }
.empty-state p { font-size: 0.88rem; }

/* ── WORD PROFILE ── */
.profile-hero {
  border: 2px solid var(--black);
  padding: 28px 28px 22px;
  margin-bottom: 20px;
  background: var(--white);
}

.profile-word { font-size: 2.8rem; font-weight: 700; letter-spacing: -2px; line-height: 1; margin-bottom: 14px; }

.profile-pos {
  background: var(--black);
  color: var(--white);
  padding: 2px 10px;
  font-size: 0.68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: inline-block;
  margin-right: 8px;
}

.profile-phonetic { font-size: 0.9rem; color: var(--text-muted); font-style: italic; }

.profile-audio-btn {
  background: var(--red);
  border: none;
  padding: 4px 12px;
  font-size: 0.72rem;
  font-weight: 600;
  cursor: pointer;
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  transition: background 0.12s;
}

.profile-audio-btn:hover { background: var(--red-hover); }

.profile-main-def {
  border-left: 3px solid var(--red);
  padding: 12px 18px;
  margin-bottom: 20px;
  background: var(--white);
  font-size: 0.92rem;
  line-height: 1.65;
  border: 1px solid var(--border);
  border-left: 3px solid var(--red);
}

.profile-tabs {
  display: flex;
  margin-bottom: 20px;
  border: 2px solid var(--black);
  overflow-x: auto;
  background: var(--white);
}

.profile-tab {
  flex: 1;
  min-width: fit-content;
  padding: 9px 14px;
  border: none;
  border-right: 1px solid var(--border);
  background: transparent;
  font-family: 'Inter', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  cursor: pointer;
  color: var(--text-muted);
  transition: all 0.12s;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  white-space: nowrap;
}

.profile-tab:last-child { border-right: none; }
.profile-tab:hover { background: var(--bg); color: var(--black); }
.profile-tab.active { background: var(--black); color: var(--white); font-weight: 600; }
.profile-content { animation: fadeUp 0.2s ease; }

.profile-def-card { border: 1px solid var(--border); padding: 16px 20px; margin-bottom: 10px; background: var(--white); }
.profile-pos-badge { background: var(--light); padding: 2px 10px; font-size: 0.68rem; font-weight: 600; display: inline-block; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); }
.profile-def-text { font-size: 0.9rem; line-height: 1.6; margin-bottom: 8px; }
.profile-def-example { font-style: italic; font-size: 0.82rem; color: var(--text-muted); padding-top: 8px; border-top: 1px solid var(--border); }

.profile-example-card {
  border: 1px solid var(--border);
  border-bottom: none;
  padding: 14px 18px;
  display: flex;
  gap: 14px;
  align-items: flex-start;
  line-height: 1.65;
  font-size: 0.88rem;
  background: var(--white);
}

.profile-example-card:last-child { border-bottom: 1px solid var(--border); }

.example-number {
  background: var(--red);
  color: var(--white);
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.68rem;
  font-weight: 700;
  flex-shrink: 0;
}

.nuance-card { border: 1px solid var(--border); border-bottom: none; padding: 14px 18px; background: var(--white); }
.nuance-card:last-child { border-bottom: 1px solid var(--border); }
.nuance-card.highlight-card { border: 2px solid var(--black); background: var(--black); color: var(--white); margin-bottom: 4px; }
.nuance-card.highlight-card .nuance-def { color: #aaa; }
.nuance-word { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 4px; }
.nuance-def { font-size: 0.85rem; line-height: 1.55; color: #555; }

.memory-card {
  border: 2px solid var(--black);
  padding: 32px;
  text-align: center;
  background: var(--black);
  color: var(--white);
}

.memory-text { font-size: 0.95rem; line-height: 1.8; font-style: italic; }

.source-card { border: 1px solid var(--border); border-bottom: none; padding: 16px 20px; background: var(--white); }
.source-card:last-child { border-bottom: 1px solid var(--border); }

.source-link {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 4px 12px;
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text);
  text-decoration: none;
  transition: all 0.12s;
  display: inline-block;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin: 3px;
}

.source-link:hover { background: var(--black); color: var(--white); border-color: var(--black); }

/* ── RELATED CHIP ── */
.related-chip {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 2px 10px;
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text);
  display: inline-block;
  cursor: pointer;
  transition: all 0.12s;
  margin: 2px;
}

.related-chip:hover { background: var(--black); color: var(--white); border-color: var(--black); }

/* ── CONTEXTUAL / CONTEXT PANEL ── */
.context-card { border: 2px solid var(--black); padding: 20px; margin-bottom: 14px; background: var(--white); }

.context-label {
  display: block;
  font-size: 0.68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 8px;
  color: var(--text-muted);
}

.context-textarea {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid var(--border);
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  color: var(--text);
  outline: none;
  resize: vertical;
  line-height: 1.6;
  background: var(--white);
}

.context-textarea:focus { border-color: var(--black); }

.context-error {
  border: 2px solid var(--red);
  padding: 10px 14px;
  font-size: 0.85rem;
  color: var(--red);
  margin-top: 10px;
  background: var(--red-light);
}

.context-result { border: 2px solid var(--black); padding: 24px; margin-top: 16px; background: var(--white); }

.result-word {
  font-family: 'Playfair Display', serif;
  font-size: 1.7rem;
  font-weight: 700;
  margin-bottom: 18px;
  letter-spacing: -0.5px;
}

.result-section { margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
.result-section:last-of-type { border-bottom: none; }

.result-label {
  font-size: 0.65rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  margin-bottom: 6px;
}

.result-explanation { font-size: 0.9rem; line-height: 1.65; }

.result-simpler {
  font-size: 0.85rem;
  line-height: 1.6;
  color: #555;
  font-style: italic;
  padding: 10px 14px;
  background: var(--bg);
  border-left: 3px solid var(--red);
}

/* ── FLASHCARDS ── */
.flashcard-page { max-width: 540px; margin: 0 auto; padding: 40px 32px; text-align: center; }
.flashcard-page h2 { font-size: 1.8rem; margin-bottom: 4px; letter-spacing: -0.5px; }
.flashcard-page .subtitle { color: var(--text-muted); margin-bottom: 36px; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em; }

.flashcard { width: 100%; height: 220px; cursor: pointer; perspective: 1000px; margin: 0 auto 24px; }
.flashcard-inner { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; transition: transform 0.45s ease; }
.flashcard-inner.flipped { transform: rotateY(180deg); }

.flashcard-front, .flashcard-back {
  position: absolute; width: 100%; height: 100%;
  backface-visibility: hidden;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 24px; border: 2px solid var(--black);
}

.flashcard-front { background: var(--white); }
.flashcard-front h1 { font-size: 2.2rem; font-weight: 700; letter-spacing: -1px; }
.flashcard-front .hint { font-size: 0.65rem; color: var(--text-muted); margin-top: 12px; text-transform: uppercase; letter-spacing: 0.1em; }

.flashcard-back { background: var(--black); color: var(--white); transform: rotateY(180deg); }
.flashcard-back .meaning { font-size: 0.9rem; line-height: 1.65; text-align: center; }
.flashcard-back .example { font-size: 0.78rem; color: #888; font-style: italic; margin-top: 10px; text-align: center; }

.flashcard-controls { display: flex; border: 2px solid var(--black); background: var(--white); }
.flashcard-controls .btn { border: none; border-right: 1px solid var(--border); padding: 10px 22px; flex: 1; }
.flashcard-controls .btn:last-child { border-right: none; }
.card-counter { padding: 10px 18px; font-size: 0.72rem; color: var(--text-muted); display: flex; align-items: center; border-right: 1px solid var(--border); text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap; }

/* ── QUIZ ── */
.quiz-page { max-width: 540px; margin: 0 auto; padding: 40px 32px; }
.quiz-page h2 { font-size: 1.8rem; margin-bottom: 6px; text-align: center; letter-spacing: -0.5px; }

.score-badge {
  background: var(--black); color: var(--white);
  font-size: 0.68rem; font-weight: 600;
  padding: 4px 14px; margin: 0 auto 24px;
  display: block; width: fit-content;
  text-transform: uppercase; letter-spacing: 0.08em;
}

.quiz-card { border: 2px solid var(--black); padding: 28px; margin-bottom: 16px; text-align: center; background: var(--white); }
.quiz-word { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; margin-bottom: 6px; letter-spacing: -0.5px; }
.quiz-instruction { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.07em; }

.quiz-options { border: 2px solid var(--black); background: var(--white); }

.quiz-option {
  padding: 12px 18px; border: none;
  border-bottom: 1px solid var(--border);
  background: var(--white);
  font-family: 'Inter', sans-serif; font-size: 0.85rem;
  cursor: pointer; text-align: left;
  transition: all 0.12s; color: var(--text);
  width: 100%;
}

.quiz-option:last-child { border-bottom: none; }
.quiz-option:hover:not(:disabled) { background: var(--bg); padding-left: 26px; }
.quiz-option.correct { background: #e8f5e9; color: #1b5e20; font-weight: 600; }
.quiz-option.wrong { background: var(--red-light); color: var(--red); }
.quiz-option:disabled { cursor: default; }

.quiz-feedback { text-align: center; margin-top: 14px; font-weight: 600; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em; }
.quiz-feedback.correct { color: #1b5e20; }
.quiz-feedback.wrong { color: var(--red); }

/* ── OCR ── */
.ocr-upload-area { border: 2px dashed var(--border-strong); padding: 56px 20px; text-align: center; cursor: pointer; transition: all 0.12s; background: var(--white); }
.ocr-upload-area:hover { border-color: var(--black); background: var(--bg); }
.ocr-upload-area .emoji { font-size: 2.2rem; margin-bottom: 10px; }

.ocr-preview-box { border: 2px solid var(--black); padding: 18px; background: var(--white); }
.ocr-preview-img { width: 100%; max-height: 380px; object-fit: contain; margin-bottom: 14px; }
.ocr-preview-actions { display: flex; border: 2px solid var(--black); }
.ocr-preview-actions .btn { border: none; border-right: 1px solid var(--border); flex: 1; }
.ocr-preview-actions .btn:last-child { border-right: none; }

/* ── PDF READER ── */
.reader-left {
  display: flex; flex-direction: column;
  border-right: 2px solid var(--black);
  overflow: hidden;
  background: var(--white);
}

.reader-toolbar {
  display: flex; align-items: center;
  border-bottom: 2px solid var(--black);
  background: var(--white);
  flex-shrink: 0;
}

.reader-toolbar .btn { border: none; border-right: 1px solid var(--border); padding: 11px 18px; font-size: 0.75rem; }

.reader-page-controls { display: flex; align-items: center; }
.reader-page-controls .btn { border: none; border-right: 1px solid var(--border); padding: 11px 14px; }
.reader-page-controls span { padding: 0 14px; font-size: 0.72rem; color: var(--text-muted); white-space: nowrap; text-transform: uppercase; letter-spacing: 0.06em; border-right: 1px solid var(--border); }

.reader-canvas-container {
  flex: 1; overflow-y: auto; overflow-x: auto;
  padding: 20px; background: #e8e8e8;
  display: flex; justify-content: center; align-items: flex-start;
}

.reader-empty {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  height: 100%; min-height: 400px;
  color: var(--text-muted); cursor: pointer; text-align: center;
}

.pdf-text-layer {
  position: absolute; top: 0; left: 0;
  overflow: hidden; pointer-events: auto;
  user-select: text; -webkit-user-select: text;
}

.pdf-text-layer span {
  color: transparent; position: absolute;
  white-space: pre; cursor: text;
  transform-origin: 0% 0%;
}

.pdf-text-layer ::selection { background: rgba(192,57,43,0.2); color: transparent; }

.reader-right { overflow-y: auto; padding: 22px; background: var(--white); }
.reader-tip { border: 1px solid var(--border); padding: 14px; font-size: 0.82rem; line-height: 1.6; margin-bottom: 14px; background: var(--bg); }
.reader-selected-text { border: 1px solid var(--border); padding: 10px 14px; margin-bottom: 4px; background: var(--bg); }
.reader-result { margin-top: 18px; padding-top: 18px; border-top: 2px solid var(--black); }

/* ── LOADING ── */
.loading-dots { display: flex; gap: 5px; justify-content: center; }
.loading-dots span { width: 7px; height: 7px; background: var(--red); animation: bounce 1.2s infinite ease-in-out; }
.loading-dots span:nth-child(2) { animation-delay: 0.2s; }
.loading-dots span:nth-child(3) { animation-delay: 0.4s; }

mark { background: rgba(192,57,43,0.12); color: var(--text); padding: 1px 2px; font-weight: 600; }

.confidence-badge { font-size: 0.68rem; font-weight: 600; padding: 2px 10px; text-transform: uppercase; letter-spacing: 0.06em; }
.confidence-badge.high { background: #e8f5e9; color: #1b5e20; }
.confidence-badge.medium { background: var(--light); color: var(--mid); }
.confidence-badge.low { background: var(--red-light); color: var(--red); }

/* ── IMPORT MESSAGE ── */
.import-msg {
  padding: 10px 14px;
  font-size: 0.82rem;
  font-weight: 500;
  margin-bottom: 16px;
  border: 1.5px solid;
}

.import-msg.success { border-color: #1b5e20; background: #e8f5e9; color: #1b5e20; }
.import-msg.error { border-color: var(--red); background: var(--red-light); color: var(--red); }

/* ── WORD PROFILE MODAL (inline) ── */
.word-profile-inline {
  border: 2px solid var(--black);
  margin-top: 20px;
  background: var(--white);
  animation: fadeUp 0.25s ease;
}

.word-profile-inline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 20px;
  border-bottom: 2px solid var(--black);
  background: var(--black);
  color: var(--white);
}

.word-profile-inline-header h3 {
  font-size: 1.2rem;
  font-weight: 700;
  font-family: 'Playfair Display', serif;
  letter-spacing: -0.3px;
}

.word-profile-inline-close {
  background: none;
  border: none;
  color: #888;
  cursor: pointer;
  font-size: 1rem;
  transition: color 0.12s;
  padding: 0;
}

.word-profile-inline-close:hover { color: var(--white); }

.word-profile-inline-body { padding: 20px; }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .sidebar { position: relative; width: 100%; min-height: auto; flex-direction: row; flex-wrap: wrap; }
  .main-content { margin-left: 0; }
  .reader-layout { margin-left: 0; grid-template-columns: 1fr; grid-template-rows: 55vh auto; height: auto; }
  .stats-row { flex-wrap: wrap; }
  .stat-card { min-width: 45%; }
  .page-container { padding: 24px 16px; }
}
