import { useEffect, useState } from "react";
import api from "../api";

function Quiz() {

    const [quiz, setQuiz] = useState(null);
    const [score, setScore] = useState(0);
    const [answered, setAnswered] = useState(false);

    useEffect(() => {
        loadQuiz();
    }, []);

    const loadQuiz = async () => {
        const res = await api.get("/words/quiz");
        setQuiz(res.data);
        setAnswered(false);
    };

    const checkAnswer = (option) => {

        if (answered) return;

        if (option === quiz.correctAnswer) {
            setScore(score + 1);
        }

        setAnswered(true);
    };

    if (!quiz) return <h2>Loading...</h2>;

    return (

        <div style={{
            display: "flex",
            flexDirection: "column",
            alignItems: "center",
            marginTop: "50px"
        }}>

            <h2>Quiz</h2>

            <h3>{quiz.word}</h3>

            {quiz.options.map((opt, i) => (

                <button
                    key={i}
                    onClick={() => checkAnswer(opt)}
                    style={{
                        margin: "10px",
                        padding: "10px",
                        width: "200px"
                    }}
                >
                    {opt}
                </button>

            ))}

            <p>Score: {score}</p>

            {answered && (
                <button onClick={loadQuiz}>
                    Next Question
                </button>
            )}

        </div>
    );
}

export default Quiz;